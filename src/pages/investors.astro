---
import Layout from '@/layouts/main.astro';
import { InvestorIntro } from '@/components/InvestorIntro';

const title = 'For investors - ASIMOV Systems';
const description =
  'Invest in ASIMOV Personal Intelligence (PI)—privacy-first personal intelligence, powered by the ASIMOV Protocol. Join through our waitlist to express interest.';
const canonicalUrl = 'https://asimov.systems/investors';
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://asimov.systems/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://asimov.systems/og-image.png" />
    <meta name="twitter:image:alt" content="ASIMOV Systems - For investors" />
    <meta name="twitter:site" content="@ASIMOV_Protocol" />
  </Fragment>

  <InvestorIntro client:load />
</Layout>
