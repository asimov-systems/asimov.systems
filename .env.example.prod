# Production Environment Configuration
# Use these variables in your production deployment

# Environment
ENVIRONMENT=prod

# Account Management URL
PUBLIC_ID_AUTH_URL=https://id.asimov.systems

# Feature Flags
# Set to 'true' to enable sign-in button and authentication UI
# Set to 'false' or leave unset to hide authentication (default: hidden)
PUBLIC_ENABLE_AUTH=false

# Clerk - Production Keys (same Clerk instance for all subdomains)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
PUBLIC_CLERK_PUBLISHABLE_KEY_PROD=pk_live_...
CLERK_SECRET_KEY_PROD=sk_live_...

# Note: Clerk shares sessions across subdomains via cookie domain=.asimov.systems
# Ensure both domains are added in Clerk Dashboard → Settings → Domains

# Note: In production, never use fallback keys
# Always use the _PROD suffixed variables (and the base public key for Astro env validation)

# Note: Payment/reservation functionality is handled on id.asimov.systems
