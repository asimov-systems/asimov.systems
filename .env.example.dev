# Development Environment Configuration
# Copy this file to .env for local development

# Environment
ENVIRONMENT=dev

# Account Management URL
PUBLIC_ID_AUTH_URL=https://id.asimov.systems

# Feature Flags
# Set to 'true' to enable sign-in button and authentication UI
# Set to 'false' or leave unset to hide authentication (default: hidden)
PUBLIC_ENABLE_AUTH=false

# Clerk - Development Keys (same Clerk instance as prod)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
PUBLIC_CLERK_PUBLISHABLE_KEY_DEV=pk_test_...
CLERK_SECRET_KEY_DEV=sk_test_...

# Note: Clerk shares sessions across subdomains via cookie domain=.asimov.systems
# Ensure both domains are added in Clerk Dashboard → Settings → Domains

# Note: Payment/reservation functionality is handled on id.asimov.systems
